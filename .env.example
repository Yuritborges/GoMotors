# Banco PostgreSQL (Neon)
# Use a URL com "-pooler" para a aplicação (Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Use a URL direta (sem pooler) para migrations locais
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Chave secreta para sessão de login (gere uma string longa e aleatória)
AUTH_SECRET="troque-por-uma-chave-segura-aleatoria"

# --- Senhas (nunca commite valores reais) ---

# Seed/import local — mínimo 8 caracteres
# SEED_OWNER_PASSWORD="sua-senha-admin"
# SEED_ATTENDANT_PASSWORD="sua-senha-atendente"

# Trocar senha do admin em produção: npm run db:set-password
# ADMIN_EMAIL="matheuspoli@gomotors.local"
# ADMIN_PASSWORD="nova-senha-forte"

# Seed em banco remoto (Neon): só para resetar demo vazia — APAGA TUDO
# SEED_FORCE=1

# Testes contra Vercel (scripts/test-vercel.ps1)
# TEST_ADMIN_EMAIL="matheuspoli@gomotors.local"
# TEST_ADMIN_PASSWORD="..."

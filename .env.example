# Banco PostgreSQL (Neon)
# Use a URL com "-pooler" para a aplicação (Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Use a URL direta (sem pooler) para migrations locais
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Chave secreta para sessão de login (gere uma string longa e aleatória)
AUTH_SECRET="troque-por-uma-chave-segura-aleatoria"

{
  "name": "gomotors",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/check-branch.mjs && next dev -H 0.0.0.0",
    "build": "node scripts/vercel-build.mjs",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import tsx --test src/**/*.test.ts",
    "promote:prod": "node scripts/promote-to-prod.mjs",
    "branch:check": "node scripts/check-branch.mjs",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:set-password": "tsx scripts/set-admin-password.ts",
    "db:import": "tsx scripts/import-gomotors-data.ts",
    "db:sync-employees": "tsx scripts/sync-employees.ts",
    "db:sync-missing": "tsx scripts/sync-missing-data.ts",
    "db:reset": "prisma migrate reset --force",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^7.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}

# =============================================================================
# GoMotors — NUNCA versionar dados do cliente nem secrets
# =============================================================================

# Planilhas e exports do cliente (pasta dados/ inteira)
/dados/*
!/dados/.gitkeep

# Backups locais do banco (nunca versionar)
/backups/

# Variáveis de ambiente e secrets
.env
.env.*
!.env.example
.env.vercel
.env.local
.env.development.local
.env.test.local
.env.production.local

# =============================================================================
# Dependências e build
# =============================================================================

/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

/coverage
/.next/
/out/
/build
/dist
.turbo

# =============================================================================
# Banco local / Prisma gerado
# =============================================================================

*.db
*.db-journal
/src/generated/prisma

# =============================================================================
# Deploy e logs
# =============================================================================

.vercel
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# =============================================================================
# SO e IDE
# =============================================================================

.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.pem
.idea/
.vscode/*
!.vscode/extensions.json

